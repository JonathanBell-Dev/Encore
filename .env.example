# ── Encore / ATL Events — Environment Variables ──────────────────────────────
#
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and must never be committed.
#
# For local development you can use a local Supabase instance:
#   1. Install the Supabase CLI:  npm install -g supabase
#   2. Start locally:             supabase start
#   3. Run migrations:            supabase db push
#   4. Copy the printed URL/keys into .env
#
# For production, use your Supabase project's URL and anon key from:
#   https://supabase.com/dashboard/project/<your-project>/settings/api

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Optional: service-role key for admin scripts (never expose in the browser)
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
