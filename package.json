{
  "name": "encore-main",
  "version": "1.0.0",
  "description": "Atlanta's event discovery and community platform",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "jest --testPathPattern=tests/(?!e2e)",
    "test:unit": "jest --testPathPattern=tests/auth|tests/events",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm run test && npm run test:e2e",
    "serve": "npx serve . -l 5500"
  },
  "keywords": ["atlanta", "events", "community"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "jest": "^30.3.0"
  }
}
